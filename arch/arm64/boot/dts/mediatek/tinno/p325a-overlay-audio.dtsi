/*[TN.NJDC] audio overlay file.start*/
&i2c7 {
	/* AWINIC AW87XXX Smart K PA */
	aw87xxx_pa@58 {
		compatible = "awinic,aw87xxx_pa";
		reg = <0x58>;
		reset-gpio = <&pio 169 0>;
		dev_index = < 0 >;
		esd-enable = "false";
		status = "okay";
	};

	aw87xxx_pa@5B {
		compatible = "awinic,aw87xxx_pa";
		reg = <0x5B>;
		reset-gpio = <&pio 107 0>;
		dev_index = < 1 >;
		esd-enable = "false";
		status = "okay";
	};
    /* AWINIC AW87XXX Smart K PA End */
};

&accdet {
	/* accdet micbias voltage: 0x07,2.7v;0x05,2.5v;0x02,1.9v */
	accdet-mic-vol = <6>;
};
/*[TN.NJDC] audio overlay file.end*/
